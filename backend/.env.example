# .env.example — Environment variable template
#
# HOW TO USE:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your actual values in .env
#   3. NEVER commit .env to git (add it to .gitignore)
#
# WHY environment variables?
#   Hardcoding secrets like API keys directly in your code is dangerous.
#   If you push to GitHub, anyone can find them and use your account.
#   Environment variables keep secrets out of the codebase entirely.
#   python-dotenv loads them at runtime from the .env file.

# ── Groq API ──────────────────────────────────────────────────────────────────
# Get your free key at: https://console.groq.com
# Free tier gives you: 14,400 requests/day, 30 req/min on Llama 3.3 70B
GROQ_API_KEY=your_groq_api_key_here

# ── LLM Settings ──────────────────────────────────────────────────────────────
# The model to use. Llama 3.3 70B is the best free option.
# Other options: llama3-8b-8192 (faster, cheaper, less capable)
LLM_MODEL=llama-3.3-70b-versatile

# ── Embeddings ────────────────────────────────────────────────────────────────
# The sentence-transformers model to use for generating embeddings.
# all-MiniLM-L6-v2 is the sweet spot: fast, small (~80MB), great performance.
# It gets downloaded automatically on first run from HuggingFace.
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Chroma Vector DB ──────────────────────────────────────────────────────────
# Where Chroma stores its data on disk.
# Each document gets its own collection in this directory.
CHROMA_PERSIST_DIR=./chroma_data

# ── Chunking Settings ─────────────────────────────────────────────────────────
# How many characters per chunk. ~500 tokens ≈ 1800-2000 characters.
# Too large: chunks contain noise, less precise retrieval.
# Too small: chunks lack context, answers are incomplete.
CHUNK_SIZE=1500

# Overlap between consecutive chunks (in characters).
# Overlap ensures that sentences at chunk boundaries don't get cut off,
# which would break the semantic meaning of a phrase split across two chunks.
CHUNK_OVERLAP=200

# ── Retrieval Settings ────────────────────────────────────────────────────────
# How many chunks to retrieve per query.
# More = more context for the LLM, but also more tokens = slower + costlier.
# 4 is a good balance for most documents.
TOP_K_RESULTS=4

# ── Server ────────────────────────────────────────────────────────────────────
# These match what next.config.js expects (proxies /api/py/* to :8000)
HOST=0.0.0.0
PORT=8000
